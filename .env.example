# Supabase Configuration (Modern Platform Keys)
# Note: VITE_ prefix is required for Vite to expose these to the client.
# Use your Publishable Key (starts with sb_publishable_...) NOT the legacy anon key.

VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_BUCKET=images

# Admin Configuration (CLI & Web)
# Note: SECRET_KEY is for CLI use only. Never expose in Vite!
SUPABASE_SECRET_KEY=sb_secret_...
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password
UPLOAD_DIR=./uploads
